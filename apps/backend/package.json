{
  "name": "@table-order/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:integration": "jest --config test/jest-integration.json --runInBand",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/migrations/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/migrations/data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/migrations/data-source.ts src/migrations/Auto",
    "seed": "ts-node -r tsconfig-paths/register src/scripts/seed.ts",
    "seed:starbucks": "ts-node -r tsconfig-paths/register src/scripts/seed-starbucks.ts",
    "seed:tanghuo": "ts-node -r tsconfig-paths/register src/scripts/seed-tanghuo.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.7",
    "@nestjs/core": "^10.3.7",
    "@nestjs/platform-express": "^10.3.7",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/config": "^3.2.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.3.1",
    "typeorm": "^0.3.20",
    "mysql2": "^3.9.7",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.4",
    "uuid": "^9.0.1",
    "@table-order/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.12",
    "@nestjs/testing": "^10.3.7",
    "@golevelup/ts-jest": "^0.5.0",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2",
    "testcontainers": "^10.9.0",
    "@testcontainers/mysql": "^10.9.0"
  }
}
