# ============================================================
# 테이블오더 — Docker Compose 환경변수 예시
# 사용: cp .env.example .env  후 값 채우기 (.env 는 커밋 금지)
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=table_order
MYSQL_USER=tableorder
MYSQL_PASSWORD=changeme_app

# --- Backend ---
# JWT_SECRET 은 64byte 이상 랜덤 (생성 예: openssl rand -hex 32)
JWT_SECRET=replace-with-64-byte-random-string

# --- Frontend (빌드타임 inline) ---
# NEXT_PUBLIC_API_URL 은 docker-compose build args 로 주입됨.
# 매장 PC 등 실제 호스트 배포 시 해당 IP 로 빌드 필요.
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- 공통 ---
TZ=Asia/Seoul
